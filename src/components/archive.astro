---
import { Image } from 'astro:assets';
import logo from '../assets/banner.png';

import AppIcon from '../components/ui/AppIcon.astro';
import Button from '../components/ui/Button.astro';
---

<header class="header">
  <div class="header__logo">
    <Image 
        src={logo} 
        alt="Nunchi Health Logo" 
        loading="eager" 
        width={200}
      />
  </div>
  <nav class="nav">
    <button class="nav__link" data-href="/about" aria-expanded="false" aria-controls="about">
        <span class="nav__link__text"> About </span>
        <span class="nav__link__icon">
          <AppIcon name="fa6-solid:angle-down"></AppIcon>
        </span>
    </button>
    <button class="nav__link" data-href="/our-programs" aria-expanded="false" aria-controls="our-programs">
        <span class="nav__link__text"> Our Programs </span>
        <span class="nav__link__icon">
          <AppIcon name="fa6-solid:angle-down"></AppIcon>
        </span>
    </button>
    <button class="nav__link" data-href="/get-involved" aria-expanded="false" aria-controls="get-involved">
        <span class="nav__link__text"> Get Involved </span>
        <span class="nav__link__icon">
          <!-- <AppIcon name="fa6-solid:angle-down"></AppIcon> -->
          <svg viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1px"><use href="#openArrowHead"></use></svg>
        </span>
    </button>
    <button class="nav__link" data-href="/shop" aria-expanded="false" aria-controls="shop">
        <span class="nav__link__text"> Shop </span>
    </button>
  </nav>
  <div class="header__button">
    <Button textContent="Support Nunchi" link="/donate"></Button>        
  </div>
</header>
  
<style lang="scss">
  @use '../styles/variables.scss' as *;

    .header {
        display: flex;
        justify-content: space-between;
        width: 100%;
        padding: 4vw;

        position: relative;
        z-index: 2;
        width: 100%;
        box-sizing: border-box;
        padding-top: 2vw;
        padding-bottom: 2vw;
        padding-left: 3vw;
        padding-right: 3vw;
        pointer-events: auto;

        background: $color--tan;
        // box-shadow: 0px 12px 12px 0px;

        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        width: 100%;
        height: inherit;
        
        &__logo {}

        .nav { 
          display: flex;
          flex-direction: row;
          
          &__link {
            background: none  ;
            border: none;
            align-items: center;
            box-sizing: border-box; 

            border: none;
            font: inherit;
            color: inherit;
            text-decoration: inherit;
            text-transform: inherit;
            letter-spacing: inherit;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            min-width: 0;
            width: auto;
            height: auto;
            line-height: inherit;
            text-align: inherit;
            vertical-align: baseline;
            &__text {
              background: none;
              border: none;
              font: inherit;
              color: inherit;
              text-decoration: inherit;
              text-transform: inherit;
              letter-spacing: inherit;
              cursor: pointer;
              display: inline-flex;
              align-items: center;
              min-width: 0;
              width: auto;
              height: auto;
              line-height: inherit;
              text-align: inherit;
              vertical-align: baseline;
            }
            &__icon {
            }
          }
        }

        &__button {
          font-size: 1rem;
        }
    }
</style>