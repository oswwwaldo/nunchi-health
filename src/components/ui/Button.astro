---
interface Props {
  textContent?: string;
  link?: string;
}

const { textContent = "Learn more", link = "#" } = Astro.props;
---

<a class="button" href={link}>
    {textContent}   
</a>

<style lang="scss">
  @use '../../styles/variables.scss' as *;

    .button {
        display: inline-block;
        background: black;
        color: $color--white;
        border-radius: 15px;
        overflow-wrap: break-word;
        pointer-events: auto;
        padding: 24px 35px;

        font-weight: 500;   
        font-size: 15px;
        text-align: center;
        text-size-adjust: 100%;
        text-decoration: none;

        transition: normal 0s 0.1s opacity linear;

        &:hover {
            opacity: 0.7;
        }
    }
</style>

