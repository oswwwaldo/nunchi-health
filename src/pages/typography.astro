---
// src/pages/typography.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Typography | Nunchi Health";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="typography-guide">
    
    <div class="typography-group">
      <h1>Heading 1</h1>
      <h2>Heading 2</h2>
      <h3>Heading 3</h3>
      <h4>Heading 4</h4>
    </div>

    <div class="typography-group">
      <p class="text-large">Paragraph 1 (Large)</p>
      <p>Paragraph 2 (Base/Standard)</p>
      <p class="text-small">Paragraph 3 (Small)</p>
      <code>Monospace</code>
    </div>

    <div class="typography-group">
      <p><strong>Typography (Bold)</strong></p>
      <p><em>Typography (Italic)</em></p>
      <p><del>Typography (Strikethrough)</del></p>
    </div>

  </section>
</BaseLayout>

<style lang="scss">
  .typography-guide {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .typography-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    &:not(:last-child) {
      padding-bottom: 2rem;
      border-bottom: 1px solid #e5e5e5;
    }
  }
</style>